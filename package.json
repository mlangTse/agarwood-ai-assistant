{
  "name": "agarwood-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "setup:start": "scripts/local-supabase-flow.sh",
    "verify:start": "scripts/local-supabase-flow.sh --smoke",
    "dev:next": "node scripts/run-next-command.mjs next dev",
    "build": "node scripts/run-next-command.mjs next build",
    "wiki:build": "node scripts/build-llm-wiki.mjs",
    "wiki:check-routing": "node scripts/check-rag-routing.mjs",
    "wiki:sync": "node scripts/sync-llm-wiki-rag.mjs",
    "wiki:deploy": "npm run wiki:build && npm run wiki:sync",
    "start": "node scripts/run-next-command.mjs next start",
    "lint": "node scripts/run-next-command.mjs next lint",
    "typecheck": "tsc --noEmit",
    "doctor:mac": "xattr -dr com.apple.provenance node_modules .next 2>/dev/null || true",
    "clean:cache": "rm -rf .next tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "openai": "4.67.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.2"
  }
}
