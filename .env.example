# OpenAI is optional for now. Leave OPENAI_API_KEY empty to use local fallback responses.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=30000
CHAT_TIMEOUT_MS=35000

# Public Supabase client config. These values are safe to expose in browser bundles.
NEXT_PUBLIC_SUPABASE_URL=https://qqyisexdvlefnzwwtkrt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase admin key. Never commit the real value to GitHub.
# Set this in .env.local locally and in Tencent Cloud environment variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
