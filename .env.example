# App is served below https://mlangtse.top/agarwood in production.
NEXT_PUBLIC_BASE_PATH=/agarwood

# PostgreSQL. TencentDB PostgreSQL or a self-hosted PostgreSQL with pgvector both work.
DATABASE_URL=postgresql://agarwood:change-me@127.0.0.1:5432/agarwood_ai
POSTGRES_SSL=false
POSTGRES_POOL_MAX=10

# Domestic model API with chat-completions compatible routes. Swap base URL and model names for DeepSeek, Hunyuan, Kimi, Qwen, etc.
MODEL_API_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=
MODEL_CHAT_MODEL=deepseek-chat
MODEL_EMBEDDING_MODEL=text-embedding-v1
MODEL_EMBEDDING_DIMENSIONS=1536
MODEL_EMBEDDING_DISABLED=false
MODEL_API_TIMEOUT_MS=30000

CHAT_TIMEOUT_MS=35000
RAG_TIMEOUT_MS=12000
